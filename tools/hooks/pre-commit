#!/usr/bin/env bash
# pre-commit — keep generated artifacts in sync with their sources.
#
# Two responsibilities:
#  1. Rebuild spine/content.js when any manuscript markdown is staged.
#  2. Re-stamp the cache-bust hash on spine/*.html when any spine asset
#     (CSS / JS / HTML) is staged.
#
# The deploy workflow uploads /spine/ as-is, so stale generated files mean
# a stale rendered site. Both steps stage the regenerated files into the
# same commit.
#
# To activate in a fresh clone:
#   git config core.hooksPath tools/hooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- 1. Rebuild content.js when manuscript markdown changes --------------

if git diff --cached --name-only --diff-filter=ACMR \
     | grep -E '^spine/([^/]+\.md|meta\.json|build-content\.js)$' \
     > /dev/null; then
  echo "pre-commit: spine source staged — rebuilding content.js"
  node spine/build-content.js
  if ! git diff --cached --quiet -- spine/content.js \
     || ! git diff --quiet -- spine/content.js; then
    git add spine/content.js
    echo "pre-commit: staged regenerated spine/content.js"
  fi
fi

# --- 2. Re-stamp cache-bust hash when any asset or HTML changes ----------
# Runs after content.js rebuild above so the hash reflects the latest content.
# Idempotent — no-op if the hash hasn't changed.

if git diff --cached --name-only --diff-filter=ACMR \
     | grep -E '^spine/[^/]+\.(css|js|html)$' \
     > /dev/null; then
  echo "pre-commit: spine asset/HTML staged — stamping cache-bust hash"
  node spine/stamp-assets.js
  # Stage every spine HTML the stamp (or build-content.js earlier) modified
  # in the working tree. Glob picks up section-N.html files automatically.
  for h in spine/*.html; do
    if [ -f "$h" ] && ! git diff --quiet -- "$h"; then
      git add "$h"
    fi
  done
fi
