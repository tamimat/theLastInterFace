#!/usr/bin/env bash
# pre-commit — keep generated artifacts in sync with their sources.
#
# Two responsibilities:
#  1. Rebuild site/content.js when any manuscript markdown is staged.
#  2. Re-stamp the cache-bust hash on site/*.html when any site asset
#     (CSS / JS / HTML) is staged.
#
# The deploy workflow uploads /site/ as-is, so stale generated files mean
# a stale rendered site. Both steps stage the regenerated files into the
# same commit.
#
# To activate in a fresh clone:
#   git config core.hooksPath tools/hooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- 1. Rebuild content.js when manuscript markdown changes --------------
# Manuscript markdown lives under spine/. The builder lives under site/.

if git diff --cached --name-only --diff-filter=ACMR \
     | grep -E '^(spine/[^/]+\.md|spine/meta\.json|site/build-content\.js)$' \
     > /dev/null; then
  echo "pre-commit: manuscript or builder staged — rebuilding content.js"
  node site/build-content.js
  if ! git diff --cached --quiet -- site/content.js \
     || ! git diff --quiet -- site/content.js; then
    git add site/content.js
    echo "pre-commit: staged regenerated site/content.js"
  fi
fi

# --- 2. Re-stamp cache-bust hash when any asset or HTML changes ----------
# Runs after content.js rebuild above so the hash reflects the latest content.
# Idempotent — no-op if the hash hasn't changed.

if git diff --cached --name-only --diff-filter=ACMR \
     | grep -E '^site/[^/]+\.(css|js|html)$' \
     > /dev/null; then
  echo "pre-commit: site asset/HTML staged — stamping cache-bust hash"
  node site/stamp-assets.js
  # Stage every site HTML the stamp (or build-content.js earlier) modified
  # in the working tree. Glob picks up section-N.html files automatically.
  for h in site/*.html; do
    if [ -f "$h" ] && ! git diff --quiet -- "$h"; then
      git add "$h"
    fi
  done
fi
